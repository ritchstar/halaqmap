{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "halaqmap.com" }],
      "destination": "https://www.halaqmap.com/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/rate/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/partners",
      "destination": "/index.html"
    },
    {
      "source": "/partners/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/ambassadors",
      "destination": "/index.html"
    },
    {
      "source": "/ambassadors/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/barber/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/m/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/discover",
      "destination": "/index.html"
    },
    {
      "source": "/about",
      "destination": "/index.html"
    },
    {
      "source": "/privacy/:path*",
      "destination": "/index.html"
    },
    {
      "source": "/privacy-policy",
      "destination": "/index.html"
    },
    {
      "source": "/terms",
      "destination": "/index.html"
    },
    {
      "source": "/register",
      "destination": "/index.html"
    },
    {
      "source": "/register/:path*",
      "destination": "/index.html"
    }
  ],
  "framework": "vite",
  "installCommand": "npm install --no-audit --no-fund --loglevel=error",
  "buildCommand": "npm run typecheck:api && npm run build && node scripts/verify-dist-index.mjs",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/.well-known/apple-developer-merchantid-domain-association",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/plain; charset=utf-8"
        },
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/workbox-(.*).js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "no-referrer-when-downgrade"
        },
        {
          "key": "Permissions-Policy",
          "value": "geolocation=(self)"
        }
      ]
    }
  ],
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 60,
      "includeFiles": "api/_lib/assets/**"
    }
  },
  "crons": [
    {
      "path": "/api/cron-private-chat-maintenance",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron-security-triage",
      "schedule": "20 4 * * *"
    },
    {
      "path": "/api/ops-billing-monitor?cron=1",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/ops-intelligence-report?cron=1",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron-ops-health-scan",
      "schedule": "35 * * * *"
    },
    {
      "path": "/api/cron-wallet-drain-recovery",
      "schedule": "15 */6 * * *"
    }
  ]
}
