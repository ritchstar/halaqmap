{
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "functions": {
    "api/register-upload-file.ts": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/register-signed-upload.ts": {
      "memory": 512,
      "maxDuration": 30
    },
    "api/register-submission.ts": {
      "memory": 512,
      "maxDuration": 30
    },
    "api/approve-barber.ts": {
      "memory": 512,
      "maxDuration": 30
    },
    "api/send-barber-onboarding.ts": {
      "memory": 512,
      "maxDuration": 60
    }
  }
}
