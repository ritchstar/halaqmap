{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/rate/:path*",
      "destination": "/index.html"
    }
  ],
  "framework": "vite",
  "installCommand": "npm install",
  "buildCommand": "npm run typecheck:api && npm run build && node scripts/verify-dist-index.mjs",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/workbox-(.*).js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "functions": {
    "api/register-upload-file.ts": {
      "maxDuration": 60
    },
    "api/register-signed-upload.ts": {
      "maxDuration": 30
    },
    "api/register-submission.ts": {
      "maxDuration": 30
    },
    "api/register-mint-intent.ts": {
      "maxDuration": 15
    },
    "api/verify-moyasar-payment.ts": {
      "maxDuration": 20
    },
    "api/approve-barber.ts": {
      "maxDuration": 45
    },
    "api/send-barber-onboarding.ts": {
      "maxDuration": 60
    },
    "api/barber-portal-login.ts": {
      "maxDuration": 30
    },
    "api/barber-inclusive-care-update.ts": {
      "maxDuration": 20
    },
    "api/barber-portfolio.ts": {
      "maxDuration": 25
    },
    "api/admin-support-chat.ts": {
      "maxDuration": 25
    },
    "api/barber-support-chat.ts": {
      "maxDuration": 25
    },
    "api/interest-signup.ts": {
      "maxDuration": 15
    },
    "api/log-search-activity.ts": {
      "maxDuration": 20
    },
    "api/public-rate-barber-context.ts": {
      "maxDuration": 15
    },
    "api/barber-portal-magic-consume.ts": {
      "maxDuration": 15
    },
    "api/simulate-booking-overlap.ts": {
      "maxDuration": 20
    },
    "api/partner-promo.ts": {
      "maxDuration": 15
    },
    "api/partner-promo-admin.ts": {
      "maxDuration": 60
    },
    "api/admin-sentinel-preflight.ts": {
      "maxDuration": 15
    },
    "api/admin-sentinel-brief.ts": {
      "maxDuration": 60
    },
    "api/admin-sentinel-chat.ts": {
      "maxDuration": 60
    },
    "api/admin-sentinel-action.ts": {
      "maxDuration": 20
    },
    "api/ops-billing-monitor.ts": {
      "maxDuration": 60
    },
    "api/ops-intelligence-report.ts": {
      "maxDuration": 60
    },
    "api/admin-resources-ai-analyze.ts": {
      "maxDuration": 60
    },
    "api/admin/resources/update-from-ai.ts": {
      "maxDuration": 30
    },
    "api/admin-financial-archive.ts": {
      "maxDuration": 60
    },
    "api/webhooks/supabase-subscription.ts": {
      "maxDuration": 45
    }
  },
  "crons": [
    {
      "path": "/api/ops-billing-monitor?cron=1",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/ops-intelligence-report?cron=1",
      "schedule": "0 5 * * *"
    }
  ]
}
