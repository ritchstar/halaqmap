{
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "functions": {
    "api/register-upload-file.ts": {
      "maxDuration": 60
    },
    "api/register-signed-upload.ts": {
      "maxDuration": 30
    },
    "api/register-submission.ts": {
      "maxDuration": 30
    },
    "api/register-mint-intent.ts": {
      "maxDuration": 15
    },
    "api/verify-moyasar-payment.ts": {
      "maxDuration": 20
    },
    "api/approve-barber.ts": {
      "maxDuration": 30
    },
    "api/send-barber-onboarding.ts": {
      "maxDuration": 60
    },
    "api/barber-portal-login.ts": {
      "maxDuration": 30
    },
    "api/barber-inclusive-care-update.ts": {
      "maxDuration": 20
    },
    "api/interest-signup.ts": {
      "maxDuration": 15
    },
    "api/cron-private-chat-maintenance.ts": {
      "maxDuration": 15
    },
    "api/cron-security-triage.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron-private-chat-maintenance",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron-security-triage",
      "schedule": "20 4 * * *"
    }
  ]
}
