# انسخ إلى .env (لا ترفع .env إلى Git)
# cp .env.example .env   — أو: copy .env.example .env

# ── Ollama (Windows — مثبت على الجهاز) ──
USE_HOST_OLLAMA=true
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ── Open WebUI ──
OPEN_WEBUI_PORT=8080
WEBUI_SECRET_KEY=استبدل-بسلسلة-عشوائية-طويلة

RAG_EMBEDDING_MODEL=nomic-embed-text

# ── n8n — دومين ritchperfume.com ──
N8N_PORT=5678
N8N_HOST=n8n.ritchperfume.com
N8N_PROTOCOL=https
N8N_WEBHOOK_URL=https://n8n.ritchperfume.com/
N8N_ENCRYPTION_KEY=استبدل-32-حرفاً-على-الأقل-1234567890ab

TZ=Asia/Riyadh
PORTAL_PORT=8090

DOMAIN=ritchperfume.com
