# انسخ إلى .env محلي أو أضف القيم في Vercel → Environment Variables
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Vercel فقط (لا تضف بادئة VITE_) — رفع مرفقات التسجيل عبر api/register-upload-file بدون الاعتماد على سياسات تخزين anon
# SUPABASE_SERVICE_ROLE_KEY=
# يُنصح بنسخ مفتاح anon هنا أيضاً (نفس قيمة VITE_SUPABASE_ANON_KEY) حتى تتطابق دالة السيرفر مع رأس x-supabase-anon
# SUPABASE_ANON_KEY=
# إن لم تُضف SUPABASE_ANON_KEY، يجب أن يكون VITE_SUPABASE_ANON_KEY متاحاً لدالة السيرفر على Vercel (نفس القيمة حرفياً)
# عند رفع الواجهة فقط على cPanel بينما دوال /api على Vercel — أصل مشروع Vercel (بدون / في النهاية):
# VITE_REGISTRATION_API_ORIGIN=https://halaqmap.vercel.app
# محليًا: جرّب الرفع عبر نشرة بعيدة — رابط كامل لـ POST (مثلاً https://xxx.vercel.app/api/register-upload-file)
# VITE_REGISTRATION_UPLOAD_URL=
# رفع موقّع (مُفضّل): السيرفر يُصدِر token فقط؛ الرابط الكامل لـ POST (مثلاً https://xxx.vercel.app/api/register-signed-upload)
# VITE_REGISTRATION_SIGNED_URL=
# حفظ الطلب عبر السيرفر (مُفضّل لتجاوز مشاكل RLS مع anon)
# VITE_REGISTRATION_SUBMISSION_URL=
# مزامنة/اعتماد الحلاق عبر السيرفر (service role)
# VITE_APPROVE_BARBER_URL=
# تسجيل دخول لوحة الحلاق (POST): البريد من جدول barbers + نفس الرمز أدناه (Vercel فقط — لا تستخدم VITE_)
# VITE_BARBER_PORTAL_LOGIN_URL=/api/barber-portal-login
# VITE_BARBER_PORTAL_SESSION_REFRESH_URL=/api/barber-portal-session-refresh
# BARBER_PORTAL_PASSWORD=ضع_رمزاً_قوياً_يشاركه_الإدارة_مع_الحلاقين
# جلب قائمة الحلاقين العامة من السيرفر (fallback عند فشل RLS في المتصفح)
# VITE_PUBLIC_BARBERS_URL=
# إرسال بريد التعليمات للحلاق (روابط لوحة التحكم + شرح البنرات)
# إن وُجد VITE_REGISTRATION_API_ORIGIN فسيُستخدم تلقائياً لـ /api/send-barber-onboarding ما لم تضبط الرابط الكامل أدناه
# VITE_BARBER_ONBOARDING_EMAIL_URL=
# الإنتاج: الرفع عبر api/* + service role فقط. للطوارئ فقط — السماح بالرفع المباشر بمفتاح anon من المتصفح:
# VITE_REGISTRATION_ALLOW_ANON_UPLOAD=true

# مزود البريد (Resend) لدوال Vercel:
# RESEND_API_KEY=re_xxx
# RESEND_FROM_EMAIL=Halaqmap <onboarding@your-domain.com>
# بريد يُعرض في رسالة ترحيب الحلاق (قسم «مساعدتك تهمنا») — اختياري
# BARBER_SUPPORT_EMAIL=support@your-domain.com
# أو: SUPPORT_EMAIL= (نفس الغرض)
# رابط مباشر لمحادثة/ملاحظات العميل مع الإدارة في بريد الترحيب (يفضّل صفحة تواصل أو واتساب)
# BARBER_ADMIN_FEEDBACK_URL=https://www.halaqmap.com/#/about
# أو بريد لبناء mailto: تلقائياً
# ADMIN_FEEDBACK_EMAIL=feedback@your-domain.com

# أصل الموقع العام (JSON-LD وروابط؛ يُفضّل مطابقة النطاق في Google مثل https://www.halaqmap.com)
# VITE_SITE_ORIGIN=https://www.halaqmap.com
# (بديل مدعوم في الكود: VITE_PUBLIC_APP_ORIGIN — نفس الغرض)

# بريد الإدارة (يجب أن يطابق مستخدم Supabase Auth + دالة is_jwt_platform_admin في SQL)
# VITE_ADMIN_EMAIL=ritchstar4@gmail.com

# مسار البوابة الخفي للإدارة: الدخول = {BASE}/in ، اللوحة = {BASE}/ctrl (لا تضع روابط لهما في الواجهة العامة)
# VITE_ADMIN_PORTAL_BASE=/x7k-m9q2-a4
# عند تغيير VITE_ADMIN_EMAIL: حدّث is_jwt_platform_admin() في supabase/migrations/15_admin_jwt_platform_rls.sql وأعد تنفيذها.

# بيانات وهمية في لوحة الإدارة (طلبات/مدفوعات/إحصائيات تجريبية). الإنتاج: false أو احذف السطر.
# VITE_ADMIN_SHOW_MOCKS=false
# للصفحة الرئيسية: اسمح بـ SELECT على جدول barbers للزائر (RLS) أو سيُستخدم العرض التجريبي عند الفشل.

# كتالوج العرض التجريبي (موقوف افتراضياً لحماية الإنتاج من الحلاقين الافتراضيين).
# فعّله يدوياً فقط للعرض الداخلي: true
# VITE_DEMO_CATALOG=true

# مرفقات التسجيل: نفّذ migration 17_registration_uploads_storage.sql في Supabase لإنشاء الحاوية
# registration-uploads وسياسات الرفع للزائر (anon) تحت مجلد رقم الطلب HM-YYYYMMDD-XXXXXX.

# نهاية عرض التحويل البنكي: خصم 10% + شهران إضافيان (8 أشهر). بعد هذا التاريخ: 6 أشهر بالسعر الكامل.
# VITE_BANK_TRANSFER_PROMO_END=2026-12-31

# ضريبة القيمة المضافة في الواجهة (اختياري — الافتراضي معطّل). التحكم الأساسي من لوحة الإدارة → الإعدادات.
# عند الحاجة لتهيئة أولى بدون لوحة إدارة: فعّل ثم حدّد النسبة.
# VITE_PLATFORM_VAT_DEFAULT_ENABLED=false
# VITE_PLATFORM_VAT_DEFAULT_PERCENT=15

# اختياري — بناء الإنتاج مع رسائل المسارات (افتراضياً معطّل في production)
# VITE_ENABLE_ROUTE_MESSAGING=true
