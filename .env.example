# انسخ إلى .env محلي أو أضف القيم في Vercel → Environment Variables
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# للصفحة الرئيسية: اسمح بـ SELECT على جدول barbers للزائر (RLS) أو سيُستخدم العرض التجريبي عند الفشل.

# نهاية عرض التحويل البنكي: خصم 10% + شهران إضافيان (8 أشهر). بعد هذا التاريخ: 6 أشهر بالسعر الكامل.
# VITE_BANK_TRANSFER_PROMO_END=2026-12-31

