# انسخ إلى .env محلي أو أضف القيم في Vercel → Environment Variables
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ——— الشات الحي (عميل ↔ صالون ذهبي/ماسي) عبر Supabase من المتصفح ———
# مطلوب للواجهة: نفس القيم على Vercel (Production + Preview إن لزم).
# في Supabase Dashboard → Authentication → Providers: فعّل «Anonymous sign-ins».
# في SQL: طبّق migrations وصولاً إلى 42 (RPC + Realtime) ويفضّل 44 (رسائل خطأ أوضح عند غياب user_id).
# كل صالون للشات يجب أن يملك barbers.user_id يشير إلى profiles.id للحلاق (حساب مسجّل).
# للـ /api/public-barbers (fallback الخريطة): على Vercel أضف أيضاً
# SUPABASE_SERVICE_ROLE_KEY و (SUPABASE_ANON_KEY أو تطابق VITE_SUPABASE_ANON_KEY مع رأس x-supabase-anon).

# Vercel فقط (لا تضف بادئة VITE_) — رفع مرفقات التسجيل عبر api/register-upload-file بدون الاعتماد على سياسات تخزين anon
# SUPABASE_SERVICE_ROLE_KEY=
# ——— Webhook اشتراك Supabase → بريد PDF العقد (POST /api/webhooks/supabase-subscription) ———
# سرّ عشوائي طويل (≥16 حرفاً) على Vercel فقط. في Supabase → Database Webhooks أضف HTTP Header:
#   x-halaqmap-subscription-webhook-secret: <نفس القيمة>
# الجدول: public.subscriptions، أحداث INSERT/UPDATE عندما يصبح record.status = active.
# SUPABASE_SUBSCRIPTION_WEBHOOK_SECRET=
# يُنصح بنسخ مفتاح anon هنا أيضاً (نفس قيمة VITE_SUPABASE_ANON_KEY) حتى تتطابق دالة السيرفر مع رأس x-supabase-anon
# SUPABASE_ANON_KEY=
# إن لم تُضف SUPABASE_ANON_KEY، يجب أن يكون VITE_SUPABASE_ANON_KEY متاحاً لدالة السيرفر على Vercel (نفس القيمة حرفياً)
# عند رفع الواجهة فقط على cPanel بينما دوال /api على Vercel — أصل مشروع Vercel (بدون / في النهاية).
# يُفضّل واحداً فقط من التالي في بناء الإنتاج (نفس القيمة): أيها وُجد أولاً يُستخدم لمسارات التسجيل وبريد الترحيب.
# VITE_API_BASE_URL=https://halaqmap.vercel.app
# VITE_API_URL=https://halaqmap.vercel.app
# VITE_REGISTRATION_API_ORIGIN=https://halaqmap.vercel.app
# محليًا: جرّب الرفع عبر نشرة بعيدة — رابط كامل لـ POST (مثلاً https://xxx.vercel.app/api/register-upload-file)
# VITE_REGISTRATION_UPLOAD_URL=
# رفع موقّع (مُفضّل): السيرفر يُصدِر token فقط؛ الرابط الكامل لـ POST (مثلاً https://xxx.vercel.app/api/register-signed-upload)
# VITE_REGISTRATION_SIGNED_URL=
# حفظ الطلب عبر السيرفر (مُفضّل لتجاوز مشاكل RLS مع anon)
# VITE_REGISTRATION_SUBMISSION_URL=
# توقيع نية التسجيل (موصى به للإنتاج): سرّ طويل عشوائي على Vercel فقط — يُصدَر عبر POST /api/register-mint-intent ويُرسل كرأس x-registration-intent مع الحفظ والرفع
# REGISTRATION_INTENT_SECRET=
# رابط كامل لـ mint عند فصل الواجهة عن Vercel (اختياري)
# VITE_REGISTRATION_MINT_INTENT_URL=https://xxx.vercel.app/api/register-mint-intent

# ——— حماية APIs العامة على Vercel (تسجيل + رفع + بوابة حلاق + CORS): حد معدّل + أصول ———
# **الإنتاج:** اضبط PUBLIC_API_ALLOWED_ORIGINS (نطاقات HTTPS الرسمية للواجهة، مفصولة بفواصل). دوال /api لا تعيد Access-Control-Allow-Origin: *؛
# بدون هذه القائمة في production لن يقبل المتصفح طلبات cross-origin من موقعك (403 عند أصل غير مصرّح).
# قائمة أصول موحّدة: تُستخدم أيضاً في registrationRouteGuard عند الضبط. يُفضّل PUBLIC_API_ALLOWED_ORIGINS؛ وإلا REGISTRATION_ALLOWED_ORIGINS.
# على Vercel Production، مسارات admin-sentinel-* تفرض تضمين https://halaqmap.com في القائمة.
# إن وُجد أكثر من نطاق في PUBLIC_API_ALLOWED_ORIGINS يُفعّل تلقائياً سلوك القائمة المتعددة (مكافئ STRICT=0) دون تعيين إضافي.
# قائمة مفردة فقط: الافتراضي صارم (يجب أن يكون العنصر https://halaqmap.com). للاستثناء: ADMIN_SENTINEL_PUBLIC_ORIGINS_STRICT=0
# PUBLIC_API_ALLOWED_ORIGINS=https://halaqmap.com
# PUBLIC_API_ALLOWED_ORIGINS=https://halaqmap.com,https://www.halaqmap.com,https://preview.example.com
# ADMIN_SENTINEL_PUBLIC_ORIGINS_STRICT=0
# REGISTRATION_ALLOWED_ORIGINS=
# حد الطلبات لكل IP لكل مسار تسجيل/رفع (افتراضي 45) ونافذة بالمللي ثانية (افتراضي 60000)
# REGISTRATION_RATE_LIMIT_MAX=45
# REGISTRATION_RATE_LIMIT_WINDOW_MS=60000
# حد أشد لمسارات barber-portal-* (افتراضي: min(30, REGISTRATION_RATE_LIMIT_MAX) ما لم تُضبط القيمة التالية)
# BARBER_PORTAL_RATE_LIMIT_MAX=20
# مزامنة/اعتماد الحلاق عبر السيرفر (service role)
# VITE_APPROVE_BARBER_URL=
# تسجيل دخول لوحة الحلاق (POST): البريد من جدول barbers + نفس الرمز أدناه (Vercel فقط — لا تستخدم VITE_)
# VITE_BARBER_PORTAL_LOGIN_URL=/api/barber-portal-login
# VITE_BARBER_PORTAL_SESSION_REFRESH_URL=/api/barber-portal-session-refresh
# BARBER_PORTAL_PASSWORD=ضع_رمزاً_قوياً_يشاركه_الإدارة_مع_الحلاقين
# رابط «فتح لوحة التحكم» في بريد الترحيب (ذهبي/ماسي): توقيع HMAC + استهلاك لمرة واحدة (جدول barber_portal_magic_redemptions — migration 39)
# بدون السرّ يُستخدم رابط الدخول العادي. يمكن الاعتماد على REGISTRATION_INTENT_SECRET إن وُجد.
# BARBER_PORTAL_MAGIC_SECRET=
# BARBER_PORTAL_MAGIC_TTL_MS=259200000
# VITE_BARBER_PORTAL_MAGIC_CONSUME_URL=/api/barber-portal-magic-consume
# جلب قائمة الحلاقين العامة من السيرفر (fallback عند فشل RLS في المتصفح)
# VITE_PUBLIC_BARBERS_URL=
# إرسال بريد التعليمات للحلاق (روابط لوحة التحكم + شرح البنرات) — POST نفس أصل Vercel + `/api/send-barber-onboarding`
# للاستدعاء من Edge Webhook: عيّن ONBOARDING_INTERNAL_WEBHOOK_SECRET هنا أيضاً (يُرسل في رأس x-onboarding-internal-secret)
# ما لم تضبط الرابط الكامل أدناه، يُبنى المسار من: VITE_API_BASE_URL ثم VITE_API_URL ثم VITE_REGISTRATION_API_ORIGIN ثم مسار نسبي `/api/...` (نفس النطاق فقط).
# VITE_BARBER_ONBOARDING_EMAIL_URL=
# بريد ملخص طلب التسجيل + رابط الدفع من صفحة «تم استلام طلبك» — POST /api/send-registration-payment-summary
# يتطلب: RESEND_* + SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY (للتحقق من تطابق البريد مع registration_submissions)
# عند فصل الواجهة عن Vercel — رابط كامل (اختياري):
# VITE_SEND_REGISTRATION_PAYMENT_SUMMARY_URL=https://xxx.vercel.app/api/send-registration-payment-summary
# إجراءات إدارة دفع ميسر بعد «قيد المراجعة» — POST /api/admin-barber-subscription-action (صلاحية review_payments)
# VITE_ADMIN_BARBER_SUBSCRIPTION_ACTION_URL=https://xxx.vercel.app/api/admin-barber-subscription-action
# الإنتاج: الرفع عبر api/* + service role فقط. للطوارئ فقط — السماح بالرفع المباشر بمفتاح anon من المتصفح:
# VITE_REGISTRATION_ALLOW_ANON_UPLOAD=true

# مزود البريد (Resend) لدوال Vercel:
# RESEND_API_KEY=re_xxx
# RESEND_FROM_EMAIL=Halaqmap <onboarding@your-domain.com>
# بريد يُعرض في رسالة ترحيب الحلاق (قسم «مساعدتك تهمنا») — اختياري
# BARBER_SUPPORT_EMAIL=support@your-domain.com
# أو: SUPPORT_EMAIL= (نفس الغرض)
# رابط مباشر لمحادثة/ملاحظات العميل مع الإدارة في بريد الترحيب (يفضّل صفحة تواصل أو واتساب)
# BARBER_ADMIN_FEEDBACK_URL=https://www.halaqmap.com/#/about
# أو بريد لبناء mailto: تلقائياً
# ADMIN_FEEDBACK_EMAIL=feedback@your-domain.com

# أصل الموقع العام (JSON-LD وروابط البريد ورابط الدفع؛ يُفضّل مطابقة النطاق الفعلي مثل https://halaqmap.com أو https://www.halaqmap.com)
# VITE_SITE_ORIGIN=https://halaqmap.com
# الرقم الوطني الموحد (7054117093) — معرّف السجل التجاري المعتمد · مضبوط في src/config/partnerLegal.ts
# (خادم Vercel — PDF العقد الموحّد) LEGAL_COMMERCIAL_REGISTRATION=7054117093
# LEGAL_COMMERCIAL_REGISTRATION=
# (اختياري) رابط ملف TTF عربي لتحميله عند توليد PDF العقد — الافتراضي Noto Naskh Arabic من GitHub:
# PARTNER_CONTRACT_ARABIC_FONT_URL=
# الرقم الوطني الموحد (700xxxxxxxx) مضبوط في الكود: src/config/partnerLegal.ts — LEGAL_NATIONAL_UNIFIED_NUMBER
# (بديل مدعوم في الكود: VITE_PUBLIC_APP_ORIGIN — نفس الغرض)

# بريد الإدارة (يجب أن يطابق مستخدم Supabase Auth + دالة is_jwt_platform_admin في SQL)
# VITE_ADMIN_EMAIL=ritchstar4@gmail.com
# حساب المؤسّس (bootstrap): نفس البريد أعلاه + admin@halaqmap.com دائماً؛ صلاحيات كاملة ووضع «المالك» في الواجهة.
# لإضافة مؤسسين إضافيين (مفصولة بفواصل) دون تغيير الكود — يجب أن يطابقوا JWT في SQL:
# VITE_EXTRA_BOOTSTRAP_ADMIN_EMAILS=you@halaqmap.com
# اسم الظهور في رأس لوحة الإدارة لحساب المؤسّس (اختياري):
# VITE_ADMIN_OWNER_DISPLAY_NAME=المؤسّس — حلاق ماب

# مسار البوابة الخفي للإدارة: الدخول = {BASE}/in ، اللوحة = {BASE}/ctrl ، الوكيل = {BASE}/sentinel (لا تضع روابط في الواجهة العامة)
# يجب أن يطابق البناء الرابط الذي تفتحه (مثال الإنتاج). عدة قواعد مفصولة بفاصلة لتسجيل أكثر من Route:
# VITE_ADMIN_PORTAL_BASE=/x7k-m9q2-a4
# VITE_ADMIN_PORTAL_BASE=/x7k-m9q2-a4,/_hmap-int-9kz2

# روابط لوحة «التكاليف والتزامات» في الإدارة (اختياري — الافتراضي في الكود لمشروعكم الحالي)
# VITE_OPS_SUPABASE_DASHBOARD_URL=https://supabase.com/dashboard/project/lqzuhkzfhdhaosstduas
# VITE_OPS_VERCEL_BILLING_URL=https://vercel.com/halaqmap/~/settings/billing
# إعدادات النطاق في GoDaddy (رابط المحفظة — قد يتغيّر مع ventureId)
# VITE_OPS_GODADDY_DOMAIN_SETTINGS_URL=https://dcc.godaddy.com/control/portfolio/halaqmap.com/settings?ventureId=...

# ——— جدولة مزامنة ops-billing (/api/ops-billing-monitor?cron=1) ———
# Vercel يضيف تلقائياً Authorization: Bearer <CRON_SECRET>. بديل اختياري: OPS_BILLING_CRON_SECRET
# CRON_SECRET=...
# OPS_BILLING_CRON_SECRET=...
# اختياري — نفس قيمة CRON_SECRET أو OPS_BILLING_CRON_SECRET؛ مع جلسة مشرف يُرسل في X-Ops-Billing-Cron-Authorization ويبقى Authorization لـ JWT (لا يصل للمتصفح بدون بادئة VITE_)
# VITE_OPS_BILLING_CRON_SECRET=...

# ——— تقرير الذكاء التشغيلي اليومي (/api/ops-intelligence-report?cron=1) ———
# جدولة Vercel: 0 5 * * * UTC = 08:00 Asia/Riyadh
# يُجمّع تقارير OPS_MANAGER (24 ساعة) → موجز المؤسس في التغذية التشغيلية + بريد داخلي
# OPS_INTELLIGENCE_CRON_SECRET=...  (اختياري — بديل لـ CRON_SECRET)
# FOUNDER_OPS_DIGEST_EMAIL=founder@example.com,admin@halaqmap.com  (اختياري — افتراضي: بريد المؤسس bootstrap)

# ——— محرك التشغيل الخلفي (/api/ops-event-router) ———
# أحداث صامتة: تسجيل، دفع، اعتماد، فحص دوري → Slack / بريد / platform_ops_controller_reports
# OPS_EVENT_ROUTER_SECRET=...  (رأس x-ops-event-secret لـ webhooks Supabase أو مسارات داخلية)
# OPS_EVENT_SLACK_WEBHOOK=https://hooks.slack.com/...  (اختياري — بديل: SECURITY_TRIAGE_SLACK_WEBHOOK)
# OPS_EVENT_ROUTER_CRON_SECRET=...  (اختياري — بديل لـ CRON_SECRET)
# جدولة Vercel: /api/cron-ops-health-scan كل ساعة (طلبات معلّقة، user_id ناقص، دفعات فاشلة)
# Supabase Database Webhook (اختياري): INSERT registration_submissions أو payments → POST /api/ops-event-router

# مفتاح Admin للمنظّمة + معرّف المنظّمة (مراقبة تكلفة API — GET /v1/organization/costs مع رأس OpenAI-Organization):
# المفتاح من https://platform.openai.com/settings/organization/admin-keys — لا تستخدم مفتاح المشروع الافتراضي ولا OPENAI_API_KEY هنا.
# REVENUE_BILLING_MONITOR_TOKEN=sk-...
# بديل صريح لنفس المفتاح: OPENAI_ADMIN_KEY=sk-...
# مطلوب مع المفتاح أعلاه — معرّف org-… من إعدادات المنظّمة في OpenAI (لا تلتزم المستودع به؛ ضعه في Vercel فقط).
# OPENAI_ORGANIZATION_ID=org-...

# ——— الوكيل المراقب العام (Admin Sentinel) — خادم Vercel فقط (بدون بادئة VITE_) ———
# مفتاح OpenAI لمسار /api/admin-sentinel-chat (لا تضعه في المتصفح؛ لا تستخدم VITE_OPENAI_API_KEY)
# OPENAI_API_KEY=sk-...
# مفتاح Admin للمنظّمة (بديل لـ REVENUE_BILLING_MONITOR_TOKEN في مزامنة ops-billing فقط)
# OPENAI_ADMIN_KEY=sk-...
# نموذج الدردشة الإدارية (الافتراضي في الكود: gpt-4o)
# ADMIN_SENTINEL_OPENAI_MODEL=gpt-4o
# يتطلب طلبات API من عميل الوكيل إرسال الرأس x-halaqmap-admin-sentinel: 1 (يُضاف تلقائياً من الواجهة). عطّل للاختبار اليدوي:
# ADMIN_SENTINEL_REQUIRE_UI_HEADER=0
# اختياري: قائمة IP للمدير، MFA aal2، كلمة مرور العمليات — راجع وثائق Sentinel في الكود
# ADMIN_SENTINEL_IP_ALLOWLIST=
# ADMIN_SENTINEL_REQUIRE_AAL2=true
# ADMIN_SENTINEL_OPS_PASSWORD=
# عند تغيير VITE_ADMIN_EMAIL: حدّث is_jwt_platform_admin() في supabase/migrations/15_admin_jwt_platform_rls.sql وأعد تنفيذها.
# صلاحيات المشرفين التفصيلية: جدول platform_admin_roles (عمود permissions JSON). نفّذ migration 57_platform_admin_permissions_extend.sql بعد 18 لإضافة مفاتيح بوابات الدفع والتعامل الفردي مع المشترك.

# بيانات وهمية في لوحة الإدارة (طلبات/مدفوعات/إحصائيات تجريبية). الإنتاج: false أو احذف السطر.
# VITE_ADMIN_SHOW_MOCKS=false
# للصفحة الرئيسية: اسمح بـ SELECT على جدول barbers للزائر (RLS) أو سيُستخدم العرض التجريبي عند الفشل.

# كتالوج العرض التجريبي (موقوف افتراضياً لحماية الإنتاج من الحلاقين الافتراضيين).
# فعّله يدوياً فقط للعرض الداخلي: true
# VITE_DEMO_CATALOG=true

# مرفقات التسجيل: نفّذ migration 17_registration_uploads_storage.sql في Supabase لإنشاء الحاوية
# registration-uploads وسياسات الرفع للزائر (anon) تحت مجلد رقم الطلب HM-YYYYMMDD-XXXXXX.

# نهاية العرض التشغيلي للتحويل البنكي: خلالها خصم 10% على إجمالي 6 أشهر + 3 أشهر صلاحية إضافية (9 أشهر). بعده: 6 أشهر بالسعر الكامل فقط.
# VITE_BANK_TRANSFER_PROMO_END=2026-12-31
# بيانات التحويل البنكي (تُعرض في صفحة دفع الاشتراك النصف سنوي):
# VITE_BANK_TRANSFER_BANK_NAME_AR=البنك الأول السعودي (SAB)
# VITE_BANK_TRANSFER_BENEFICIARY=اسم صاحب الحساب
# VITE_BANK_TRANSFER_IBAN=SA00XXXXXXXXXXXXXXXXXXXXXX

# ——— ميسر (Moyasar) — بوابة الدفع ———
# مزود الدفع الموحّد:
# - واجهة الواجهة الأمامية: VITE_PAYMENT_GATEWAY=MOYASAR أو SAB
# - واجهة الخادم: PAYMENT_GATEWAY=MOYASAR أو SAB
# VITE_PAYMENT_GATEWAY=MOYASAR
# PAYMENT_GATEWAY=MOYASAR
#
# الوثائق: https://docs.mysr.dev/ | الشروط (عربي): https://moyasar.com/ar/resources/terms/
# المفتاح العام فقط في الواجهة (Vite). المفتاح السري في Vercel فقط — لا تضف VITE_ للسرّي.
# وضع الدفع: test أو live (الافتراضي test لبيئة Sandbox)
# PAYMENT_ENV=test
# مفاتيح واجهة ميسر المنفصلة:
# VITE_MOYSAR_PUBLISHABLE_TEST_API_KEY=pk_test_...
# VITE_MOYSAR_PUBLISHABLE_LIVE_API_KEY=pk_live_...
# مفاتيح خادمية منفصلة للتحقق:
# MOYSAR_SECRET_TEST_API_KEY=sk_test_...
# MOYSAR_SECRET_LIVE_API_KEY=sk_live_...
# توافق رجعي (إن استخدمت مفتاحاً واحداً فقط):
# VITE_MOYSAR_PUBLISHABLE_API_KEY=pk_test_...
# MOYSAR_SECRET_API_KEY=sk_test_...
# اختياري — افتراضياً https://api.moyasar.com/v1
# MOYSAR_API_BASE=https://api.moyasar.com/v1
# بعد الدفع يعيد ميسر التوجيه مع ?id= — يجب أن يكون callback على HTTPS ومسار ثابت في لوحة ميسر
# VITE_MOYSAR_CALLBACK_URL=https://www.halaqmap.com/#/partners/payment
# التحقق من الدفع: GET /api/verify-moyasar-payment?id=...&expectedAmount=...&expectedCurrency=SAR (expected اختياري)
# عند فصل الواجهة عن Vercel — رابط كامل للتحقق (اختياري)
# VITE_VERIFY_MOYSAR_PAYMENT_URL=https://xxx.vercel.app/api/verify-moyasar-payment
#
# إعدادات بوابات الدفع من لوحة الإدارة (جدول platform_payment_settings): نفّذ migration 56_platform_payment_settings.sql
# الواجهة العامة تقرأ /api/public-payment-page-config — بلا أسرار.

# Webhook ميسر (Supabase Edge Function `moyasar-webhook`): نفّذ migration 51 ثم انشر الدالة.
# في لوحة Moyasar → Webhooks: Endpoint = https://<project-ref>.supabase.co/functions/v1/moyasar-webhook
# Secret Token = نفس القيمة التي تضيفها كـ Secret في Supabase: MOYASAR_WEBHOOK_SECRET
# أسرار منفصلة لـ Sandbox/Live:
# MOYASAR_WEBHOOK_TEST_SECRET=...
# MOYASAR_WEBHOOK_LIVE_SECRET=...
# أسرار إضافية للدالة: RESEND_API_KEY، RESEND_FROM_EMAIL (تأكيد paid + تنبيه فشل الدفع)
# اختياري: رابط فاتورة وهمي عند عدم وصول metadata.invoice_url من ميسر
# INVOICE_PLACEHOLDER_URL=https://www.halaqmap.com/#/partners/payment?invoice=pending
# MOYASAR_WEBHOOK_SECRET=ضع_نفس_الرمز_السري_من_لوحة_Moyasar
# تفعيل تلقائي + بريد ترحيب من الـ Webhook: نفس السر في Supabase Edge وفي Vercel، وأصل الموقع الذي يستضيف /api/send-barber-onboarding
# ONBOARDING_INTERNAL_WEBHOOK_SECRET=رمز_عشوائي_طويل
# APP_PUBLIC_ORIGIN=https://www.halaqmap.com
# (بديل: PUBLIC_SITE_ORIGIN)
#
# ——— رخص الإدراج الرقمية (migration 76) ———
# Vercel + Supabase Edge: نفس القيم على كلا الجانبين
# LISTING_LICENSE_VOUCHER_PEPPER=رمز_عشوائي_طويل_لتجزئة_أكواد_القسائم
# LISTING_LICENSE_INTERNAL_SECRET=رمز_لاستدعاء_/api/listing-license-fulfill-internal_من_webhook_ميسر
#
# ——— SAB Bank (تحضير الربط) ———
# مفاتيح Sandbox / Live لبوابة بنك الأول حسب صيغة البنك:
# SAB_MERCHANT_ID_TEST=
# SAB_MERCHANT_ID_LIVE=
# SAB_SECRET_TEST=
# SAB_SECRET_LIVE=
# SAB_WEBHOOK_TEST_SECRET=
# SAB_WEBHOOK_LIVE_SECRET=

# ——— WhatsApp Automation Draft (معطّل افتراضياً) ———
# لا يُرسل أي رسالة واتساب حتى تفعيل المفتاح أدناه:
# ENABLE_WHATSAPP_PAYMENT_NOTIFICATIONS=false
# WHATSAPP_PROVIDER=twilio
# سر داخلي لاستدعاء /api/send-payment-whatsapp-draft من webhook (اختياري؛ إن لم يُضبط يستخدم ONBOARDING_INTERNAL_WEBHOOK_SECRET)
# WHATSAPP_INTERNAL_WEBHOOK_SECRET=رمز_عشوائي_طويل
#
# Twilio WhatsApp:
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# endpoint اختبار القالب: /api/send-whatsapp-template-test
# رأس الحماية المطلوب: x-whatsapp-test-secret
# WHATSAPP_TEMPLATE_TEST_SECRET=رمز_اختبار_واتساب
#
# Meta WhatsApp Cloud API:
# META_WHATSAPP_TOKEN=
# META_WHATSAPP_PHONE_NUMBER_ID=

# ضريبة القيمة المضافة في الواجهة (اختياري — الافتراضي معطّل). التحكم الأساسي من لوحة الإدارة → الإعدادات.
# عند الحاجة لتهيئة أولى بدون لوحة إدارة: فعّل ثم حدّد النسبة.
# VITE_PLATFORM_VAT_DEFAULT_ENABLED=false
# VITE_PLATFORM_VAT_DEFAULT_PERCENT=15

# اختياري — بناء الإنتاج مع رسائل المسارات (افتراضياً معطّل في production)
# VITE_ENABLE_ROUTE_MESSAGING=true

# ——— مساعد الشركاء (ذكاء اصطناعي) ———
# واجهة الشركاء تستدعي /api/partner-assistant-chat افتراضياً، ويمكن تغييره:
# VITE_PARTNER_ASSISTANT_CHAT_URL=/api/partner-assistant-chat
# المزود المفضل على الخادم: openai أو anthropic (اختياري)
# PARTNER_ASSISTANT_PROVIDER=openai
# مفاتيح الخادم (Vercel فقط — بدون VITE_)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# موديلات اختيارية:
# PARTNER_ASSISTANT_OPENAI_MODEL=gpt-4o-mini
# PARTNER_ASSISTANT_ANTHROPIC_MODEL=claude-3-5-haiku-20241022
# حد الطلبات لمسار المساعد لكل IP (افتراضي 20/الدقيقة):
# PARTNER_ASSISTANT_RATE_LIMIT_MAX=20
# عند البناء: يُلحق بروابط /assets/*.js و*.css في dist/index.html (كسر كاش CDN). الافتراضي 2.
# VITE_INDEX_ASSET_CACHE_QUERY=2

# ——— تنبيهات تواصل الحلاق (Web Push — مرحلة 2) ———
# أنشئ مفاتيح VAPID: npx web-push generate-vapid-keys
# VITE_VAPID_PUBLIC_KEY=...   (للمتصفح — نفس المفتاح العام)
# VAPID_PUBLIC_KEY=...        (للخادم — نفس قيمة VITE_VAPID_PUBLIC_KEY)
# VAPID_PRIVATE_KEY=...       (Vercel فقط — لا VITE_)
# VAPID_SUBJECT=mailto:support@your-domain.com
# BARBER_CHAT_PUSH_WEBHOOK_SECRET=رمز_عشوائي_طويل
# في Supabase → Database Webhooks → INSERT على private_messages
# URL: https://your-vercel.app/api/barber-chat-push-dispatch
# Header: x-barber-chat-push-secret = BARBER_CHAT_PUSH_WEBHOOK_SECRET
# VITE_BARBER_CHAT_PUSH_URL=/api/barber-chat-push

# ——— Engineering Wing — Handshake + Autonomous Council (Vercel فقط — بدون VITE_) ———
# POST /api/admin-engineering-handshake — يفعّل Operations Controller للمؤسس عند System Status: OK
# نفّذ migration: supabase/migrations/86_platform_engineering_handshake.sql
# Handshake Required (مع SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY أعلاه):
# VERCEL_TOKEN=vcp_...
# VERCEL_PROJECT_ID=prj_...
# GITHUB_TOKEN=ghp_...  (أو github_pat_...)
# Handshake Optional — التنفيذ الفعلي بعد «Approve Execution» في لوحة المؤسس (بدونه: stub):
# CURSOR_API_KEY=
# CURSOR_ENGINEERING_MODEL=composer-2
# محليًا فقط (لا ترفع إلى Git): .agent_secrets.env — نفس المفاتيح أعلاه + SUPABASE_SERVICE_KEY كبديل لـ SUPABASE_SERVICE_ROLE_KEY
# AI Staff labs (Technical Consultant / Public Prosecutor): OPENAI_API_KEY أعلاه — مطلوب للمحادثة وليس للـ Handshake

# ——— Vercel: بناء نظيف عند تعليق الباندل القديم (نفس الاسم المشفّر رغم نشر main) ———
# في لوحة Vercel → Project → Settings → Environment Variables → Production (وPreview إن لزم):
# VERCEL_FORCE_NO_BUILD_CACHE=1
# يجبر المنصة على عدم إعادة استخدام Build Cache. بعد التحقق احذف المتغير أو عيّنه 0 إن أردت تسريع البناء.
# عند إعادة النشر من الواجهة: اختر أحدث Deployment من Git ثم Redeploy، أو استخدم CLI: vercel deploy --prod --force
